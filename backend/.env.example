# ========================================================================
# CRITICAL ENVIRONMENT VARIABLES - Dev Codex Backend
# ========================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!

# ========================================================================
# REQUIRED FOR ALL ENVIRONMENTS
# ========================================================================

# Database Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dev-codex-dev
# Production example: mongodb+srv://username:password@cluster.mongodb.net/dev-codex-prod

# JWT Security (CRITICAL: Generate a secure random string)
JWT_SECRET=your-super-secure-32-char-jwt-secret
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# CSRF Protection Secret (CRITICAL: Required in production)
CSRF_SECRET=your-super-secure-64-char-csrf-secret
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Application Environment
NODE_ENV=development # Set to 'production' for production deployment

# Self-Hosted Mode (disables rate limiting and billing)
SELF_HOSTED=false # Set to 'true' for self-hosted deployments without billing/rate limits

# ========================================================================
# PRODUCTION ONLY - REQUIRED
# ========================================================================

# CORS Origins (Required in production)
CORS_ORIGINS=http://localhost:5002
# Production example: https://yourdomain.com,https://www.yourdomain.com

# Support Email (Required for ticket system)
SUPPORT_EMAIL=support@gmail.com
# Production example: support@yourdomain.com

# Frontend URL
FRONTEND_URL=http://localhost:5002
# Production example: https://yourdomain.com

# ========================================================================
# EMAIL SERVICE (Optional but recommended)
# ========================================================================
# Unified email service - supports EITHER Resend OR SMTP (or both for failover)
# Pick ONE option below (or set both for automatic failover)

# OPTION 1: Resend (What production uses)
# Get your API key from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000 emails/month
# RESEND_API_KEY=re_your_api_key_here

# OPTION 2: SMTP (Recommended for self-hosting)
# Works with: Gmail, SendGrid, Mailgun, your own server, etc.
# Gmail: Enable 2FA, then get app password at https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# OPTION 3: Both (automatic failover)
# Set both RESEND_API_KEY and SMTP_* - app tries Resend first, falls back to SMTP

# How it works: ALL emails (invitations, password resets, tickets, admin) use this service
# If neither configured: App works but email features disabled (can't invite, reset passwords, etc.)

# =========================================================================
# GOOGLE OAUTH (Optional)
# =========================================================================
# Get from: https://console.developers.google.com/

# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# =========================================================================
# STRIPE BILLING (Optional - only for hosted version with paid plans)
# =========================================================================
# Only needed if running a hosted version with billing
# If self-hosting, set SELF_HOSTED=true and skip these

# STRIPE_SECRET_KEY=sk_test_... (use sk_live_... for production)
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_... (Pro plan price ID)
# STRIPE_PRICE_ID_PREMIUM=price_... (Premium plan price ID)

# =========================================================================
# MONITORING & ERROR TRACKING (Optional but recommended)
# =========================================================================
# Sentry for error tracking and performance monitoring

SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_RELEASE=v1.0.0
LOG_LEVEL=info

# =========================================================================
# ADMIN USER CREATION (Self-hosted setup)
# =========================================================================
# Use these with backend/src/scripts/create-admin.ts to create an admin user
# Run: npm run create-admin (after setting these values)

# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=YourSecurePassword123
# ADMIN_FIRST_NAME=Admin
# ADMIN_LAST_NAME=User
# ADMIN_CREATION_SECRET=your-secret-key-here
# EXPECTED_ADMIN_SECRET=your-secret-key-here (must match ADMIN_CREATION_SECRET)

# =========================================================================
# DEVELOPMENT HELPERS
# =========================================================================
# These are automatically handled in development

# PORT=5003 (automatically set)
# TRUST_PROXY=true (set in production only)

# =========================================================================
# AI (Gemini / Ollama)
# =========================================================================
# AI Provider — auto-detected from NODE_ENV
# Production (NODE_ENV=production): Uses Gemini API (OpenAI-compatible endpoint)
# Development: Uses local Ollama

# Required for production
# GEMINI_API_KEY=AIza...

# Local Ollama instance for dev ($0 cost)
# Install: https://ollama.ai — then: ollama pull qwen2.5:3b
# WSL2 users: use Windows host gateway IP (ip route show default | awk '{print $3}')
OLLAMA_BASE_URL=http://localhost:11434

# Override model (default: gemini-2.5-flash for prod, qwen2.5:3b for dev)
OLLAMA_MODEL=qwen2.5:3b

# Kill switch
AI_ENABLED=true

# ── Ollama Keep-Alive (set on the Ollama container/server, NOT here) ──
# Controls how long models stay loaded in VRAM/RAM after the last request.
# Set as an env var on your Ollama Docker container or system service:
#   OLLAMA_KEEP_ALIVE=0    → never unload (no cold starts, ~4-8GB RAM)
#   OLLAMA_KEEP_ALIVE=5m   → unload after 5 min idle (default, saves RAM)
#   OLLAMA_KEEP_ALIVE=-1   → same as 0 (never unload)
# Docker example: docker run -d -e OLLAMA_KEEP_ALIVE=0 -v ollama:/root/.ollama -p 11434:11434 --name ollama ollama/ollama
# Add --gpus all for NVIDIA GPU acceleration (optional, AMD not supported)